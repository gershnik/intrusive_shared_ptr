@PACKAGE_INIT@


# Avoid repeatedly including the targets
if(NOT TARGET isptr::isptr)
    include(${CMAKE_CURRENT_LIST_DIR}/isptr-exports.cmake)

    function(isptr_add_module target_name visibility)
        set(_base ${CMAKE_CURRENT_FUNCTION_LIST_DIR})
        set(_files ${_base}/isptr.cppm)
        target_sources(${target_name} ${visibility}
            FILE_SET thinsqlitepp_module TYPE CXX_MODULES BASE_DIRS ${_base} FILES ${_files}
        )
    endfunction()

endif()


